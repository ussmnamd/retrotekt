# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_...

# Email address that receives contact form submissions
CONTACT_EMAIL_TO=shahan@retrotekt.com

# Sentry — get DSN from sentry.io > Project > Settings > Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=retrotekt
SENTRY_AUTH_TOKEN=sntrys_...
